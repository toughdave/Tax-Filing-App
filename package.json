{
  "name": "canada-tax-filing-app",
  "version": "0.20.0",
  "private": true,
  "description": "Security-first CRA-oriented filing app for individual, self-employed, and company workflows.",
  "scripts": {
    "dev": "next dev --port 3000",
    "dev:https": "next dev --experimental-https --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "version:bump": "node scripts/bump-version.mjs",
    "security:scan": "npm audit --audit-level=high",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.3.1",
    "@vercel/blob": "^2.3.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.577.0",
    "next": "^15.1.6",
    "next-auth": "^4.24.11",
    "otpauth": "^9.5.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "resend": "^6.9.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.10.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.6",
    "postcss": "^8.4.49",
    "prisma": "^6.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
