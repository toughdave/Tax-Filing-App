# Core app
NODE_ENV=development
NEXTAUTH_URL=https://localhost:3000
NEXTAUTH_SECRET=replace-with-long-random-value

# Database (Canada-hosted PostgreSQL recommended for production)
# For Vercel Postgres: set DATABASE_URL to the pooled connection string
# and DIRECT_URL to the non-pooled (direct) connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/canada_tax_filing?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/canada_tax_filing?schema=public

# Optional OAuth providers (enable one or more)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

APPLE_ID=
APPLE_SECRET=

# Demo credentials provider for local development only
DEMO_EMAIL=demo@canadataxfiling.local
DEMO_PASSCODE=change-me-immediately
# Set to true only for controlled non-production demos.
# In production, demo credentials stay disabled unless this is explicitly true.
ENABLE_DEMO_AUTH=
